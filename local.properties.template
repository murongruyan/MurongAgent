# MurongAgent — local.properties 模板
# 复制此文件为 local.properties 并填入你的 SDK/NDK 路径

# Windows
# sdk.dir=C:\\Users\\<用户名>\\AppData\\Local\\Android\\Sdk
# ndk.dir=C:\\Users\\<用户名>\\AppData\\Local\\Android\\Sdk\\ndk\\30.0.14904198

# macOS
# sdk.dir=/Users/<用户名>/Library/Android/sdk
# ndk.dir=/Users/<用户名>/Library/Android/sdk/ndk/30.0.14904198

# Linux
# sdk.dir=/home/<用户名>/Android/Sdk
# ndk.dir=/home/<用户名>/Android/Sdk/ndk/30.0.14904198
